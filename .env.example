# Claude API key — utilisée par les skills LLM (idée business, script vidéo, prompt Veo)
# Obtenir une clé : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google AI / Gemini API key — utilisée UNIQUEMENT pour la génération vidéo Veo 3.1
# Obtenir une clé (avec billing activé) : https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# Apify API token — utilisée pour la skill Maps Grounding (compass/google-maps-scraper)
# Récupérable sur https://console.apify.com/settings/integrations
APIFY_TOKEN=apify_api_...

# X (Twitter) OAuth 2.0 PKCE — utilisée par la skill x_dm
# 1. Créer une app sur https://developer.x.com
# 2. Type d'app: "Web App" / OAuth 2.0
# 3. AJOUTER cette redirect URI: http://localhost:3000/api/auth/x/callback
# 4. Scopes requis: tweet.read, users.read, dm.write, offline.access
# 5. 💰 X est pay-as-you-go (credit-based) — ~$0.025 / DM envoyé.
#    Acheter des crédits dans Developer Console.
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/x/callback

PORT=3000

# AWS Bedrock Credentials — utilisée pour la skill build_saas
# Assure-toi d'activer l'accès au modèle Claude 3.5 Sonnet dans ta console Amazon Bedrock.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=us.anthropic.claude-3-5-sonnet-20241022-v2:0


# Zernio API key — utilisée par les skills TikTok & Instagram
# Obtenir une clé : https://zernio.com/dashboard/api-keys
ZERNIO_API_KEY=

# Redirect URIs pour Zernio callbacks
TIKTOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback
INSTA_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/insta/callback

# Mobbin Design API
MOBBIN_API_KEY=

